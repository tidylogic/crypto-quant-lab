{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "bot_name": "crypto-quant-lab-dryrun",
  "initial_state": "running",
  "dry_run": true,
  "dry_run_wallet": 1000,
  "trading_mode": "spot",
  "max_open_trades": 3,
  "stake_currency": "USDT",
  "stake_amount": 20,
  "tradable_balance_ratio": 0.99,
  "fiat_display_currency": "USD",
  "timeframe": "1m",
  "cancel_open_orders_on_exit": true,
  "exchange": {
    "name": "binance",
    "key": "",
    "secret": "",
    "ccxt_config": {
      "enableRateLimit": true
    },
    "ccxt_async_config": {
      "enableRateLimit": true
    },
    "pair_whitelist": [
      "BTC/USDT",
      "ETH/USDT"
    ],
    "pair_blacklist": []
  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_delta": 1
    }
  },
  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },
  "order_types": {
    "entry": "limit",
    "exit": "limit",
    "emergency_exit": "market",
    "force_entry": "market",
    "force_exit": "market",
    "stoploss": "market",
    "stoploss_on_exchange": false
  },
  "unfilledtimeout": {
    "entry": 1,
    "exit": 1,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": false,
    "jwt_secret_key": "change-me-change-me-change-me-change-me",
    "ws_token": "change-me-change-me-change-me-change-me",
    "CORS_origins": [],
    "username": "freqtrade",
    "password": "change-me-change-me"
  },
  "internals": {
    "process_throttle_secs": 5
  }
}
